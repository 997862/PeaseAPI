# PeaseAPI Environment Configuration
# 复制此文件为 .env 并填入实际值

APP_NAME="PeaseAPI"
APP_ENV=production
APP_DEBUG=false
APP_VERSION="1.0.0"

SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# PostgreSQL 数据库配置
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=peaseapi
DB_USERNAME=peaseapi
DB_PASSWORD=你的数据库密码
DB_CHARSET=utf8

# Redis (可选)
REDIS_ENABLED=false

# 密钥 (使用 openssl rand -hex 32 生成)
SESSION_SECRET=随机生成32位密钥
CRYPTO_SECRET=随机生成32位密钥

# 功能开关
PASSWORD_LOGIN_ENABLED=true
PASSWORD_REGISTER_ENABLED=true
EMAIL_VERIFICATION_ENABLED=false
REGISTER_ENABLED=true

# 邮件配置 (可选)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=你的邮箱密码

# 速率限制
GLOBAL_API_RATE_LIMIT=60
CRITICAL_RATE_LIMIT=10

# 配额
QUOTA_PER_UNIT=500000

# 超时
STREAMING_TIMEOUT=300
MAX_REQUEST_BODY_MB=32

# 日志
LOG_LEVEL=info
LOG_PATH=/www/wwwlogs/peaseapi
