{
    "name": "quantumnous/new-api-php",
    "description": "New API - Next-Generation LLM Gateway and AI Asset Management System (PHP Rewrite)",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "ramsey/uuid": "^4.7",
        "vlucas/phpdotenv": "^5.6",
        "respect/validation": "^2.3",
        "phpseclib/phpseclib": "^3.0",
        "spomky-labs/otphp": "^11.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "NewApi\\": "src/"
        },
        "files": [
            "src/Constants/constants.php",
            "src/Utils/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "NewApi\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
